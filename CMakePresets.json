{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "desktop-release-base",
      "hidden": true,
      "inherits": "release-base",
      "cacheVariables": {
        "ACECODE_BUILD_DESKTOP": "ON"
      }
    },
    {
      "name": "desktop-debug-base",
      "hidden": true,
      "inherits": "debug-base",
      "cacheVariables": {
        "ACECODE_BUILD_DESKTOP": "ON"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "inherits": "release-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "inherits": "debug-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "windows-x64-winlibs-debug",
      "displayName": "Windows x64 WinLibs Debug",
      "description": "Self-contained GCC, Ninja, and GDB build. Set ACECODE_WINLIBS_ROOT to the extracted mingw64 directory.",
      "inherits": "debug-base",
      "environment": {
        "PATH": "$env{ACECODE_WINLIBS_ROOT}/bin;$penv{PATH}",
        "VCPKG_MAX_CONCURRENCY": "8"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_HOST_TRIPLET": "x64-mingw-static",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "$env{ACECODE_WINLIBS_ROOT}/bin/ninja.exe"
        },
        "CMAKE_C_COMPILER": {
          "type": "FILEPATH",
          "value": "$env{ACECODE_WINLIBS_ROOT}/bin/gcc.exe"
        },
        "CMAKE_CXX_COMPILER": {
          "type": "FILEPATH",
          "value": "$env{ACECODE_WINLIBS_ROOT}/bin/g++.exe"
        },
        "CMAKE_RC_COMPILER": {
          "type": "FILEPATH",
          "value": "$env{ACECODE_WINLIBS_ROOT}/bin/windres.exe"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-x64-desktop-release",
      "displayName": "Windows x64 Desktop Release",
      "inherits": "desktop-release-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "windows-x64-desktop-debug",
      "displayName": "Windows x64 Desktop Debug",
      "inherits": "desktop-debug-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "inherits": "release-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
